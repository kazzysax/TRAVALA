# Copy to .env, fill in real values, run your command, then delete .env.
# Never commit .env. Never paste real values into chat/AI tools.

MONAD_TESTNET_RPC_URL=
MONAD_MAINNET_RPC_URL=

# Throwaway key for testnet is fine. For mainnet, the deployer key (and
# especially the treasury/master wallet key) belongs in a secrets manager or
# hardware wallet, not in this file on a server. See ../../DEPLOY_TO_MAINNET.md.
DEPLOYER_PRIVATE_KEY=

# Treasury address that collects the 0.1 MON platform fee per rating.
TREASURY_ADDRESS=

# Backend service addresses that receive roles at deploy time.
BACKEND_MINTER_ADDRESS=
