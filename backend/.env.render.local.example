# Copy this file to .env.render.local, fill in real values, tell me when
# done. I will run export-env-to-render.cjs, which reads this file itself and
# pushes each value straight to Render's API - I never open this file with a
# Read tool, and the export script only ever prints key names and
# success/failure, never values. Delete .env.render.local once the export
# succeeds - same reasoning as every other .env in this project.

# --- auth ---
AUTH__PRIVY_APP_ID=
AUTH__PRIVY_APP_SECRET=
AUTH__MONAD_RPC_URL=
AUTH__RELAYER_PRIVATE_KEY=

# --- relayer ---
RELAYER__MONAD_RPC_URL=
RELAYER__MASTER_WALLET_PRIVATE_KEY=
RELAYER__SPONSORSHIP_AMOUNT_MON=2
RELAYER__MONTHLY_QUOTA=20

# --- expense ---
EXPENSE__EXCHANGE_RATE_API_BASE_URL=
EXPENSE__EXCHANGE_RATE_API_KEY=

# --- ocr ---
OCR__VISION_API_KEY=
OCR__MYMEMORY_EMAIL=

# --- indexer ---
INDEXER__MONAD_RPC_URL=
INDEXER__START_BLOCK=
