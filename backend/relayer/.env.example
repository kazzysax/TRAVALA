# Copy to .env locally for dev only. Never commit .env. Never paste real
# values into chat/AI tools.

PORT=4002
MONAD_RPC_URL=

# REQUIRES: this is the master/treasury wallet - it holds real funds and
# funds every new user. It is a hard requirement (technical-plan.md 3.2, not
# optional) that this key lives in a secrets manager (AWS/GCP Secrets
# Manager, or a hardware wallet for anything beyond routine sponsorship
# payouts), never in a .env file or application code on a running server.
MASTER_WALLET_PRIVATE_KEY=

SPONSORSHIP_AMOUNT_MON=2
MONTHLY_QUOTA=20
