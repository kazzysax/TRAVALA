# Copy to .env locally for dev only. Never commit .env. Never paste real
# values into chat/AI tools. In production these live in a secrets manager,
# not in a .env file on the running service (see ../../DEPLOY_TO_MAINNET.md).

PORT=4001

# REQUIRES: Privy app credentials (dashboard.privy.io) - used for embedded
# wallet creation and auth-token verification. Dynamic/Web3Auth are the two
# named alternatives in technical-plan.md if you'd rather use one of those;
# swap privy.js for their equivalent server API and this stays a drop-in.
PRIVY_APP_ID=
PRIVY_APP_SECRET=
# Client ID from the same Privy app - public, safe to expose via /config,
# required by the vanilla @privy-io/js-sdk-core client alongside the App ID.
PRIVY_CLIENT_ID=

# Contract addresses from Stage 1's deploy output (contracts/hardhat/scripts/deploy.js).
TRAVELER_CREDENTIAL_ADDRESS=
SERVICE_RATING_ADDRESS=
SESSION_PERMISSION_ADDRESS=
MONAD_RPC_URL=

# REQUIRES: the relayer's own signing key, used only to submit
# SessionPermission.submitRatingViaSession transactions on behalf of granted
# session keys. Must come from a secrets manager in production - see
# backend/relayer/README.md for why this key is scoped and low-value by
# design (it can only ever move SessionPermission's structurally-limited
# entrypoint, never a raw ServiceRating/TravelerCredential call).
RELAYER_PRIVATE_KEY=

# REQUIRES: a dedicated signing key held only by this service, granted the
# MINTER_ROLE on the deployed TravelerCredential contract. Used exclusively
# by POST /mint (src/routes/mint.js) to mint city-stamp NFTs - gating minting
# to this one key is what prevents spam-minting and keeps gas sponsorship
# controlled (see technical-plan.md 2.1). This var was previously missing
# from this file even though routes/mint.js requires it.
MINTER_PRIVATE_KEY=
