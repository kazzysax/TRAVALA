PORT=4005

# REQUIRES: a vision/OCR API. technical-plan.md leaves the exact provider
# choice open ("default recommendation is fine") - this is written against
# Google Cloud Vision's REST API (images:annotate, TEXT_DETECTION) since it
# needs no SDK, just an API key. Swap src/lib/vision.js if you'd rather use
# AWS Textract, Azure Computer Vision, etc.
VISION_API_KEY=

# REQUIRES: a translation API. Written against Google Cloud Translate v2's
# REST API for the same "just an API key" reason. Swap src/lib/translate.js
# for DeepL or another provider if preferred.
TRANSLATE_API_KEY=
