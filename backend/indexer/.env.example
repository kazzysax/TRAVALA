PORT=4006
MONAD_RPC_URL=
SERVICE_RATING_ADDRESS=
TRAVELER_CREDENTIAL_ADDRESS=

# A real Postgres connection string - required. Indexed data (ratings,
# stamps, and the last-synced block) is persisted here so a restart never
# forces a full re-backfill from genesis/START_BLOCK again.
DATABASE_URL=

# Block to start backfilling RatingSubmitted/StampMinted events from on the
# very first run only - use the contracts' deployment block (printed by
# contracts/hardhat/scripts/deploy.js's receipt, or looked up on the block
# explorer). Every run after the first resumes from the persisted
# last-synced block instead, regardless of this value.
START_BLOCK=0
